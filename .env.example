# ============================================
# WMC EXECUTIVE PRIVATE HIRE - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and configure with your actual values
# NEVER commit .env to version control!

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=production
# Options: development, production, staging

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_USER=wmc_user
DB_PASSWORD=your_secure_database_password_here
DB_NAME=wmc_executive_hire
DB_PORT=3306

# Database Connection Pool Settings
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# ============================================
# EMAIL CONFIGURATION (Gmail Example)
# ============================================
# For Gmail: Use App-Specific Password
# 1. Enable 2-Step Verification in Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character password below

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_character_app_password
EMAIL_FROM=WMC Executive Private Hire <your_email@gmail.com>
EMAIL_TO=help@wmcprivatehire.com

# Alternative Email Providers:
# Outlook: smtp-mail.outlook.com, Port: 587
# Yahoo: smtp.mail.yahoo.com, Port: 587
# SendGrid: smtp.sendgrid.net, Port: 587

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Generate secure random strings for these:
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=generate_a_secure_random_string_here_minimum_32_characters
SESSION_SECRET=generate_another_secure_random_string_here_minimum_32_characters

# Session Configuration
SESSION_MAX_AGE=86400000
# 86400000 = 24 hours in milliseconds

# ============================================
# ADMIN CONFIGURATION
# ============================================
# Default admin credentials (CHANGE IMMEDIATELY after first login!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_EMAIL=help@wmcprivatehire.com

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
# 900000 = 15 minutes in milliseconds

RATE_LIMIT_MAX_REQUESTS=100
# Maximum requests per window

# Contact Form Rate Limit
CONTACT_RATE_LIMIT_WINDOW_MS=3600000
# 3600000 = 1 hour

CONTACT_RATE_LIMIT_MAX_REQUESTS=5
# Maximum contact form submissions per hour per IP

# ============================================
# CORS CONFIGURATION
# ============================================
# For production, set to your actual domain
FRONTEND_URL=https://yourdomain.com
# For development: http://localhost:3000
# For multiple domains: https://yourdomain.com,https://www.yourdomain.com

ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Comma-separated list of allowed origins

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=info
# Options: error, warn, info, debug

LOG_FILE_PATH=./logs/app.log
ERROR_LOG_FILE_PATH=./logs/error.log

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_ENABLED=true
CACHE_TTL=3600
# Cache Time-To-Live in seconds (3600 = 1 hour)

# Redis Configuration (if using Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
MAX_FILE_SIZE=5242880
# 5242880 = 5MB in bytes

UPLOAD_PATH=./uploads

# ============================================
# BACKUP CONFIGURATION
# ============================================
BACKUP_ENABLED=true
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=30

# ============================================
# MONITORING & ANALYTICS
# ============================================
# Google Analytics
GA_TRACKING_ID=UA-XXXXXXXXX-X

# Sentry Error Tracking (optional)
SENTRY_DSN=

# ============================================
# PAYMENT GATEWAY (Future Use)
# ============================================
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# SMS NOTIFICATIONS (Future Use)
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_REGISTRATION=false
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_PAYMENT_PROCESSING=false

# ============================================
# MAINTENANCE MODE
# ============================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We are currently performing scheduled maintenance. Please check back soon.

# ============================================
# SSL/TLS CONFIGURATION
# ============================================
SSL_ENABLED=false
SSL_KEY_PATH=
SSL_CERT_PATH=

# ============================================
# TIMEZONE
# ============================================
TZ=Europe/London

# ============================================
# NOTES
# ============================================
# 1. Never commit this file with real credentials
# 2. Keep .env in .gitignore
# 3. Use strong, unique passwords
# 4. Rotate secrets regularly
# 5. Use environment-specific .env files (.env.production, .env.staging)
# 6. For production, consider using a secrets manager (AWS Secrets Manager, Azure Key Vault, etc.)
