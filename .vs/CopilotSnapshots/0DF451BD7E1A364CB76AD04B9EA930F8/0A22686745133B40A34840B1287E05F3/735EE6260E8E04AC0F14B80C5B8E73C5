    <!-- Booking Form & Map -->
    <section class="contact-section">
        <div class="container">
            <div class="contact-grid">
                <!-- Booking Form -->
                <div class="booking-form-container">
                    <h2>Book Your Journey</h2>
                    <p class="form-intro">Fill out the form below and we'll get back to you with a quote within 30 minutes.</p>
                    
                    <form id="bookingForm" class="booking-form" novalidate>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="fullName">Full Name *</label>
                                <input type="text" id="fullName" name="fullName" required aria-required="true">
                                <span class="error-message" id="fullNameError"></span>
                            </div>
                            <div class="form-group">
                                <label for="email">Email Address *</label>
                                <input type="email" id="email" name="email" required aria-required="true">
                                <span class="error-message" id="emailError"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="phone">Phone Number *</label>
                                <input type="tel" id="phone" name="phone" required aria-required="true">
                                <span class="error-message" id="phoneError"></span>
                            </div>
                            <div class="form-group">
                                <label for="vehicle">Vehicle Type *</label>
                                <select id="vehicle" name="vehicle" required aria-required="true">
                                    <option value="">Select Vehicle</option>
                                    <option value="e-class">Mercedes E-Class (3 passengers)</option>
                                    <option value="s-class">Mercedes S-Class (3 passengers)</option>
                                    <option value="v-class">Mercedes V-Class (7 passengers)</option>
                                </select>
                                <span class="error-message" id="vehicleError"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="serviceType">Service Type *</label>
                                <select id="serviceType" name="serviceType" required aria-required="true">
                                    <option value="">Select Service</option>
                                    <option value="airport">Airport Transfer</option>
                                    <option value="corporate">Corporate Travel</option>
                                    <option value="event">Special Event</option>
                                    <option value="hourly">Hourly Hire</option>
                                    <option value="distance">Long Distance</option>
                                    <option value="other">Other</option>
                                </select>
                                <span class="error-message" id="serviceTypeError"></span>
                            </div>
                            <div class="form-group">
                                <label for="passengers">Number of Passengers *</label>
                                <input type="number" id="passengers" name="passengers" min="1" max="7" required aria-required="true">
                                <span class="error-message" id="passengersError"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="pickupLocation">Pickup Location *</label>
                                <input type="text" id="pickupLocation" name="pickupLocation" placeholder="e.g., Northampton NN1 1AA" required aria-required="true">
                                <span class="error-message" id="pickupLocationError"></span>
                            </div>
                            <div class="form-group">
                                <label for="dropoffLocation">Drop-off Location *</label>
                                <input type="text" id="dropoffLocation" name="dropoffLocation" placeholder="e.g., Heathrow Airport" required aria-required="true">
                                <span class="error-message" id="dropoffLocationError"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="pickupDate">Pickup Date *</label>
                                <input type="date" id="pickupDate" name="pickupDate" required aria-required="true">
                                <span class="error-message" id="pickupDateError"></span>
                            </div>
                            <div class="form-group">
                                <label for="pickupTime">Pickup Time *</label>
                                <input type="time" id="pickupTime" name="pickupTime" required aria-required="true">
                                <span class="error-message" id="pickupTimeError"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="returnJourney">Return Journey?</label>
                            <select id="returnJourney" name="returnJourney">
                                <option value="no">No</option>
                                <option value="yes">Yes - I need a return journey</option>
                            </select>
                        </div>

                        <div class="form-group" id="returnDateGroup" style="display: none;">
                            <label for="returnDate">Return Date</label>
                            <input type="date" id="returnDate" name="returnDate">
                        </div>

                        <div class="form-group">
                            <label for="specialRequests">Special Requests</label>
                            <textarea id="specialRequests" name="specialRequests" rows="4" placeholder="Child seats, extra luggage, flight number, etc."></textarea>
                        </div>

                        <div class="form-group checkbox-group">
                            <label class="checkbox-label">
                                <input type="checkbox" id="terms" name="terms" required aria-required="true">
                                <span>I agree to the <a href="#" target="_blank">terms and conditions</a> *</span>
                            </label>
                            <span class="error-message" id="termsError"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-large btn-full">Submit Booking Request</button>
                        
                        <p class="form-note">* Required fields. We'll respond within 30 minutes during business hours.</p>
                    </form>

                    <div id="formSuccess" class="form-success" style="display: none;">
                        <div class="success-icon">✓</div>
                        <h3>Booking Request Received!</h3>
                        <p>Thank you for your booking request. We'll contact you shortly with a confirmation and quote.</p>
                    </div>
                </div>

