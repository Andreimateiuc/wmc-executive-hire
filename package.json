{
  "name": "wmc-executive-hire",
  "version": "1.0.0",
  "description": "WMC Executive Private Hire - Luxury taxi service backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "NODE_ENV=production node server.js",
    "init-db": "node database/init-database.js",
    "add-admin": "node add-admin-user.js",
    "list-admins": "node list-admin-users.js",
    "delete-admin": "node delete-admin-user.js",
    "backup-db": "node scripts/backup-database.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "logs": "tail -f logs/combined.log",
    "logs:error": "tail -f logs/error.log",
    "clean": "rm -rf logs/* node_modules",
    "deploy": "npm run backup-db && git push heroku main"
  },
  "keywords": [
    "taxi",
    "private-hire",
    "booking-system"
  ],
  "author": "WMC Executive Private Hire",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "nodemailer": "^6.9.7",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-session": "^1.17.3",
    "moment": "^2.29.4",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "csurf": "^1.11.0",
    "cookie-parser": "^1.4.6",
    "node-cache": "^5.1.2",
    "express-mongo-sanitize": "^2.2.0",
    "hpp": "^0.2.3",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
